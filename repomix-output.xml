```

```python
@given(event_sequences)
def test_no_dangling_edges(events):
    g = build_graph(initial_graph())

    try:
        apply_events(g, events)
    except ValueError:
        return

    for u, v in g.edges:
        assert u in g.nodes
        assert v in g.nodes
```

